{
  "name": "easytransac/omnipay-easytransac",
  "description": "Easytransac gateway for Omnipay payment processing library",
  "keywords": [
    "gateway",
    "merchant",
    "omnipay",
    "easytransac"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Damien",
      "email": "damien@easytransac.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^7.4 || ^8.0 || ^8.1 || ^8.2 || ^8.3",
    "omnipay/common": "^3.2",
    "guzzlehttp/guzzle": "^7.0",
    "php-http/guzzle7-adapter": "^1.0"
  },
  "require-dev": {
    "omnipay/tests": "^4.0",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Omnipay\\Easytransac\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}